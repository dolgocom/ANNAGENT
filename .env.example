# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (Replit provides this automatically
# when you add a PostgreSQL database from the Database tab)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Anthropic AI ────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# ── Oura Ring ────────────────────────────────────────────────
# Get from https://cloud.ouraring.com/personal-access-tokens
OURA_API_TOKEN=...

# ── Session ──────────────────────────────────────────────────
# Any random string, e.g.: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-string

# ── Optional ─────────────────────────────────────────────────
# Set automatically after Anya sends /start to the bot
# COS_TELEGRAM_CHAT_ID=

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
